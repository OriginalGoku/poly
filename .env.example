# Polymarket Volatility Trading — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Riot Games API key (LoL/Valorant) — https://developer.riotgames.com/
RIOT_API_KEY=your_riot_api_key_here

# PandaScore API token (CS2) — https://pandascore.co/
PANDASCORE_TOKEN=your_pandascore_token_here
